# ─────────────────────────────────────────────
# Supabase (required for all environments)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# Auth – Google OAuth
# Client secret goes into the Supabase dashboard, NOT here.
# Supabase > Authentication > Providers > Google
#
# The Client ID is public and is used client-side for the native Google
# Identity Services sign-in (no supabase.co redirect flash). Same OAuth Web
# client as the Supabase provider. Add it in Google Cloud Console with
# majorcycle.com as an Authorized JavaScript origin, and list it under the
# Supabase Google provider's "Authorized Client IDs".
# ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─────────────────────────────────────────────
# Email – Custom SMTP password for Supabase Auth is the Resend API key below.
# (Supabase > Project Settings > Authentication > SMTP: host smtp.resend.com,
#  port 465, user "resend", password = RESEND_API_KEY, sender noreply@majorcycle.com)
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# Stripe (required for payments — F3)
# ─────────────────────────────────────────────
# Server secret. Use a RESTRICTED key (rk_…, least privilege — plan §7A), never a
# full sk_. Test key (rk_test_/sk_test_) in .env.local + Vercel Preview; live key in
# Vercel Production. Test and live are isolated Stripe environments — never mix.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_…) for /api/stripe/webhook. Test value from the
# Stripe CLI (`stripe listen`) or a test-mode endpoint; live value from the live endpoint.
STRIPE_WEBHOOK_SECRET=
# NOTE: no price-ID env vars. Prices are resolved at runtime by lookup_key
# (majorcycle_monthly / majorcycle_annual) in web/lib/stripe.ts, so the identical
# code works in both test and live (their price ids differ; lookup_keys don't).

# ─────────────────────────────────────────────
# Email – Resend (required for transactional email)
# ─────────────────────────────────────────────
RESEND_API_KEY=
# Transactional sender for app-sent account emails (deletion scheduled / account
# deleted). Optional — defaults to "MajorCycle <noreply@majorcycle.com>". (Supabase
# AUTH emails send via Supabase SMTP; the /contact form uses CONTACT_FROM_EMAIL.)
RESEND_FROM_EMAIL=
# From-address for /contact form notifications. Optional — defaults to
# "MajorCycle <support@majorcycle.com>" (reply-to is set to the submitter).
CONTACT_FROM_EMAIL=
# Where /contact form submissions are emailed. Optional — defaults to
# support@majorcycle.com (a Cloudflare Email Routing inbox → owner Gmail).
CONTACT_TO_EMAIL=

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────
# Cron (account purge — F2 Part B)
# ─────────────────────────────────────────────
# Shared secret guarding /api/cron/purge-accounts. Set the SAME value as a Vercel
# project env var named CRON_SECRET — Vercel Cron then sends it automatically as
# "Authorization: Bearer <CRON_SECRET>", and the route rejects anything else.
CRON_SECRET=

# ─────────────────────────────────────────────
# Local dev only — NEVER set in Vercel/production
# ─────────────────────────────────────────────
# Skip Supabase auth in local dev so pages can be opened/verified without a login
# (gated to NODE_ENV !== 'production' in proxy.ts). Also unlocks the local-only
# /dev-fixtures null/edge gallery. Remove after verifying. MUST NOT reach prod.
# DEV_BYPASS_AUTH=true

# ─────────────────────────────────────────────
# GitHub Actions secrets (not used locally — set in repo settings)
# SUPABASE_URL=        (same as NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# OWNER_EMAIL=         (alert destination for cron failures)
# ─────────────────────────────────────────────
